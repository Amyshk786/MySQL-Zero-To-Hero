— We are Now Creating a Table Named as ‘orders1’


CREATE TABLE orders1 (
order_id INT AUTO_INCREMENT PRIMARY KEY,
customer_id INT,
product_id INT,
quantity INT,
order_date DATE,
total_amount DECIMAL(10,2)
);





