4) If we Want to Extract Date or Time From a DATE_TIME we can use Below Command


— This is the DATE_TIME from which we want to Extract the Date & Time

SELECT CURRENT_TIMESTAMP();

+---------------------+
| CURRENT_TIMESTAMP() |
+---------------------+
| 2025-12-26 23:46:25 |
+---------------------+




— For Extracting Date use Below

SELECT DATE('2025-12-26 23:46:25') AS date_only;

+------------+
| date_only  |
+------------+
| 2025-12-26 |
+------------+





— For Extracting Time use Below

SELECT TIME('2025-12-26 23:46:25') AS time_only;
+-----------+
| time_only |
+-----------+
| 23:46:25  |
+-----------+









5) If we Want to Extract Year, Month or Day From a DATE_TIME we can use Below Command


— This is the DATE_TIME from which we want to Extract the Date & Time

SELECT CURRENT_TIMESTAMP();

+---------------------+
| CURRENT_TIMESTAMP() |
+---------------------+
| 2025-12-26 23:46:25 |
+---------------------+




— For Extracting Year use Below

SELECT EXTRACT(YEAR FROM '2025-12-27 00:17:05') AS year_only;

+-----------+
| year_only |
+-----------+
|      2025 |
+-----------+





— For Extracting Month use Below

SELECT EXTRACT(MONTH FROM '2025-12-27 00:17:05') AS month_only;

+------------+
| month_only |
+------------+
|         12 |
+------------+





— For Extracting Day use Below

SELECT EXTRACT(DAY FROM '2025-12-27 00:17:05') AS day_only;

+----------+
| day_only |
+----------+
|       27 |
+----------+








